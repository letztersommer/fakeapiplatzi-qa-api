                "exec": [
                  "//Check the request status code",
                  "pm.test('Status code is 200, request is successful', function(){",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "//Check the response headers ",
                  "pm.test(\"Access-control-allow-origin header is present in response\", function () {",
                  "    pm.response.to.have.header(\"access-control-allow-origin\");",
                  "});",
                  "",
                  "//Check the response headers ",
                  "pm.test(\"Content-Type is present in response and has value application/json\", ()=> {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "//Check the response body content",
                  "pm.test(\"Response body has a correct structure\", function () {",
                  "    let responseData = pm.response.json();",
                  "    responseData.forEach(function (product) { ",
                  "        pm.expect(product).to.include.keys([",
                  "            \"id\",",
                  "            \"title\",",
                  "            \"slug\",",
                  "            \"price\",",
                  "            \"description\",",
                  "            \"category\",",
                  "            \"images\",",
                  "            \"creationAt\",",
                  "            \"updatedAt\",",
                  "        ]);",
                  "    });",
                  "});",
                  "//Test if the response has a valid data type and format",
                  "pm.test(\"Validate data type and format of the response\", function () {",
                  "    let jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an(\"array\").and.not.to.be.empty;",
                  "    jsonData.forEach(function (product) {",
                  "        pm.expect(product.id).to.be.a(\"number\").and.to.be.above(-1);",
                  "        pm.expect(product.title).to.be.a(\"string\").and.not.to.be.empty;",
                  "        pm.expect(product.price).to.be.a(\"number\").and.to.be.above(0);",
                  "        pm.expect(product.slug).to.be.a(\"string\").and.not.to.be.empty;",
                  "        pm.expect(product.description).to.be.a(\"string\");",
                  "        pm.expect(product.images).to.be.an(\"array\");",
                  "        pm.expect(product.creationAt).to.be.a(\"string\").and.not.to.be.empty;",
                  "        pm.expect(product.updatedAt).to.be.a(\"string\").and.not.to.be.empty;",
                  "    });",
                  "});",
                  "//Test the response time",
                  "pm.test(\"Response time is less than 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
